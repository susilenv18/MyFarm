# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://susil2022_db_user:ourvideostore@clustercoffee.hn2pcni.mongodb.net/?appName=ClusterCoffee

# JWT
JWT_SECRET=Susil@2004
JWT_EXPIRE=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Email Service (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ========== DIGITALOCEAN SPACES (Image Storage) ==========
# Get these from: https://cloud.digitalocean.com/settings/api/tokens
DIGITALOCEAN_SPACES_KEY=your_access_key_here
DIGITALOCEAN_SPACES_SECRET=your_secret_key_here

# Space name & region
DIGITALOCEAN_SPACES_NAME=marketplace-assets
DIGITALOCEAN_SPACES_REGION=nyc3
DIGITALOCEAN_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# CDN URL (optional - for faster global delivery)
DIGITALOCEAN_SPACES_CDN_URL=https://marketplace-assets.nyc3.cdn.digitaloceanspaces.com

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Payment Gateway (Optional - for future integration)
STRIPE_SECRET_KEY=sk_test_your_key
RAZORPAY_KEY_ID=your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
